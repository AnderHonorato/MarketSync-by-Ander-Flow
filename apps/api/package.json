{
  "name": "@ml-manager/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "cross-env DATABASE_URL=file:./test.db node scripts/init-sqlite.mjs prisma/test.db --reset && cross-env DATABASE_URL=file:./test.db vitest run",
    "test:coverage": "cross-env DATABASE_URL=file:./test.db node scripts/init-sqlite.mjs prisma/test.db --reset && cross-env DATABASE_URL=file:./test.db vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:init:local": "node scripts/init-sqlite.mjs prisma/dev.db",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.12.0",
    "cheerio": "^1.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.61.1",
    "tesseract.js": "^5.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.14",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "prisma": "6.12.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
