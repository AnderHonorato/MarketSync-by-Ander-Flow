generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String       @id
  accountId     String?
  account       OAuthAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  usuarioId     String?
  usuario       AppUser?     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  expiresAt     DateTime
  lastSeenAt    DateTime     @default(now())
  userAgentHash String?
  ipHash        String?
  oauthAttempts OAuthAttempt[]
  auditEvents   AuditEvent[]
  aiConversations AiConversation[]

  @@index([accountId])
  @@index([usuarioId])
  @@index([expiresAt])
}

// Usuário do aplicativo (login local, separado da conta do Mercado Livre).
// Hierarquia: OWNER (fundador, acesso total e moderação) > ADMIN (empresa,
// aprovado pelo Owner) > USER (criado pelo Admin, com permissões por página).
model AppUser {
  id                 String    @id @default(cuid())
  papel              String    @default("USER")   // OWNER | ADMIN | USER
  situacao           String    @default("PENDENTE") // ATIVO | PENDENTE | SUSPENSO
  usuario            String    @unique              // nome de acesso (login)
  email              String    @unique
  senhaHash          String
  perguntaRecuperacao String
  respostaRecuperacaoHash String
  nome               String    @default("")
  cpf                String    @default("")
  perfilJson         String    @default("{}")       // telefone, endereço, etc.
  permissoesJson     String    @default("[]")       // páginas liberadas (para USER)
  // Tenancy: o Admin dono deste usuário (null para OWNER e ADMIN)
  adminPaiId         String?
  adminPai           AppUser?  @relation("AdminUsuarios", fields: [adminPaiId], references: [id], onDelete: Cascade)
  usuariosFilhos     AppUser[] @relation("AdminUsuarios")
  criadoPorId        String?
  aprovadoPorId      String?
  aprovadoEm         DateTime?
  ultimoLoginEm      DateTime?
  fotoPerfil         String?   // data URL pequena, visível no chat e no site
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sessions           Session[]
  chatEnviadas       ChatMensagem[]    @relation("MensagensEnviadas")
  chatRecebidas      ChatMensagem[]    @relation("MensagensRecebidas")
  chatPreferencias   ChatPreferencia[] @relation("PrefsDoUsuario")
  chatComoContato    ChatPreferencia[] @relation("PrefsComoContato")

  @@index([papel, situacao])
  @@index([adminPaiId])
}

// Mensagem do chat interno (1 pra 1). Apagar mensagem é "soft": o registro
// fica com apagadaEm preenchido e o texto some da visão.
model ChatMensagem {
  id        String    @id @default(cuid())
  deId      String
  de        AppUser   @relation("MensagensEnviadas", fields: [deId], references: [id], onDelete: Cascade)
  paraId    String
  para      AppUser   @relation("MensagensRecebidas", fields: [paraId], references: [id], onDelete: Cascade)
  texto     String
  apagadaEm DateTime?
  lidaEm    DateTime?
  createdAt DateTime  @default(now())

  @@index([deId, paraId, createdAt])
  @@index([paraId, lidaEm])
}

// Preferências de UMA pessoa sobre UMA conversa: fixada, arquivada e
// "apagadaAte" (apagar conversa só pra mim, sem sumir pro outro lado)
model ChatPreferencia {
  id         String    @id @default(cuid())
  usuarioId  String
  usuario    AppUser   @relation("PrefsDoUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  contatoId  String
  contato    AppUser   @relation("PrefsComoContato", fields: [contatoId], references: [id], onDelete: Cascade)
  fixada     Boolean   @default(false)
  arquivada  Boolean   @default(false)
  apagadaAte DateTime?

  @@unique([usuarioId, contatoId])
}

model AiConversation {
  id         String      @id @default(cuid())
  sessionId  String
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title      String      @default("Nova conversa")
  archivedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  messages   AiMessage[]

  @@index([sessionId, archivedAt, updatedAt])
}

model AiMessage {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String
  reasoning       String?
  attachmentsJson String         @default("[]")
  tokensJson      String         @default("{}")
  createdAt       DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model OAuthAttempt {
  id                   String   @id @default(cuid())
  sessionId            String
  session              Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stateHash            String   @unique
  codeVerifierCipher   String
  createdAt            DateTime @default(now())
  expiresAt            DateTime
  usedAt               DateTime?

  @@index([sessionId, expiresAt])
}

model OAuthAccount {
  id                   String            @id @default(cuid())
  mlUserId             String            @unique
  nickname             String
  siteId               String?
  accessTokenCipher    String?
  refreshTokenCipher   String?
  accessTokenExpiresAt DateTime?
  tokenVersion         Int               @default(0)
  lastRefreshAt        DateTime?
  revokedAt            DateTime?
  disconnectedAt       DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  sessions             Session[]
  listings             ListingSnapshot[]
  salesSnapshots       SalesSnapshot[]
  syncJobs             SyncJob[]
  bulkOperations       BulkOperation[]
  auditEvents          AuditEvent[]
}

model ListingSnapshot {
  id                  String       @id @default(cuid())
  accountId           String
  account             OAuthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  mlItemId            String
  title               String
  sku                 String?
  sellerCustomField   String?
  status              String
  price               Float
  originalPrice       Float?
  discountPercent     Float        @default(0)
  currencyId          String
  availableQuantity   Int
  soldQuantity        Int
  categoryId          String?
  condition           String?
  listingTypeId       String?
  permalink           String?
  thumbnail           String?
  catalogListing      Boolean      @default(false)
  catalogProductId    String?
  startTime           DateTime?
  stopTime            DateTime?
  lastUpdated         DateTime?
  freeShipping        Boolean      @default(false)
  picturesJson        String       @default("[]")
  attributesJson      String       @default("[]")
  variationsJson      String       @default("[]")
  shippingJson        String       @default("{}")
  rawJson             String
  internalScore       Float        @default(0)
  lastSaleDetectedAt  DateTime?
  firstSeenAt         DateTime      @default(now())
  capturedAt          DateTime      @default(now())
  lastSyncJobId       String?

  @@unique([accountId, mlItemId])
  @@index([accountId, status])
  @@index([accountId, title])
  @@index([accountId, startTime])
  @@index([accountId, lastUpdated])
  @@index([accountId, internalScore])
}

model SalesSnapshot {
  id           String       @id @default(cuid())
  accountId    String
  account      OAuthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  mlItemId     String
  soldQuantity Int
  capturedAt   DateTime     @default(now())

  @@index([accountId, mlItemId, capturedAt])
}

model SyncJob {
  id                String       @id @default(cuid())
  accountId         String
  account           OAuthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status            String       @default("QUEUED")
  kind              String       @default("FULL")
  total             Int          @default(0)
  processed         Int          @default(0)
  succeeded         Int          @default(0)
  failed            Int          @default(0)
  errorMessage      String?
  cancelRequestedAt DateTime?
  createdAt         DateTime     @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  @@index([accountId, createdAt])
  @@index([accountId, status])
}

model BulkOperation {
  id             String              @id @default(cuid())
  accountId      String
  account        OAuthAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  idempotencyKey String
  action         String
  status         String              @default("PREVIEW")
  payloadJson    String
  previewJson    String
  total          Int                 @default(0)
  succeeded      Int                 @default(0)
  failed         Int                 @default(0)
  createdAt      DateTime            @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  items          BulkOperationItem[]

  @@unique([accountId, idempotencyKey])
  @@index([accountId, createdAt])
}

model BulkOperationItem {
  id          String        @id @default(cuid())
  operationId String
  operation   BulkOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  mlItemId    String
  status      String        @default("PENDING")
  beforeJson  String
  afterJson   String
  errorCode   String?
  errorMessage String?
  attempts    Int           @default(0)
  completedAt DateTime?

  @@unique([operationId, mlItemId])
  @@index([operationId, status])
}

model AuditEvent {
  id           String        @id @default(cuid())
  accountId    String?
  account      OAuthAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sessionId    String?
  session      Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  action       String
  targetType   String?
  targetId     String?
  outcome      String
  metadataJson String        @default("{}")
  ipHash       String?
  createdAt    DateTime      @default(now())

  @@index([accountId, createdAt])
  @@index([action, createdAt])
}

model UnofficialAccess {
  id                String   @id @default(cuid())
  passwordHash      String
  recoveryQuestion  String
  recoveryAnswerHash String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
